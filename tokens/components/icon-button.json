{
  "$component": {
    "name": "IconButton",
    "className": "jspr-icon-btn",
    "prefix": "icon-btn",
    "element": "button",
    "colorAxes": ["intent", "style"],
    "sizeAxis": "size",
    "states": ["rest", "hover"],
    "interactive": true,
    "slots": {},
