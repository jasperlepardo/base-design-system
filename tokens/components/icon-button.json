      "width": "--icon-btn-box",
      "height": "--icon-btn-box",
      "border": "var(--border-width-default) solid var(--icon-btn-border)",
      "border-radius": "--icon-btn-radius",
      "background-color": "--icon-btn-bg",
      "color": "--icon-btn-icon",
      "cursor": "pointer",
      "transition": "background-color 120ms ease, border-color 120ms ease, color 120ms ease"
    }
