{
  "name": "@jasperlepardo/base-design-system",
  "version": "0.9.3",
  "type": "module",
  "license": "MIT",
  "description": "Base Design System — Tailwind-palette tokens (raw → primitives → semantics), light/dark themes, React components, built with Style Dictionary + Tailwind v4 + Storybook, mirrored into Figma.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasperlepardo/base-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "bin",
    "scripts",
    "tokens"
  ],
  "bin": {
    "jspr": "bin/jspr.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/index.css",
    "./theme": "./dist/theme.css"
  },
  "scripts": {
    "tokens:raw": "node scripts/gen-raw-from-tailwind.mjs",
    "tokens:build": "node scripts/build-tokens.mjs",
    "components:build": "node scripts/build-components.mjs",
    "tokens": "npm run tokens:raw && npm run tokens:build && npm run components:build",
    "figma:sync": "node scripts/sync-figma.mjs",
    "figma:push": "node scripts/push-figma-rest.mjs",
    "prestorybook": "npm run tokens",
    "prebuild-storybook": "npm run tokens",
    "prebuild": "npm run tokens",
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "tsc --noEmit && rimraf dist && vite build && cp src/styles/theme.css dist/theme.css",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@storybook/addon-a11y": "^8.5.0",
    "@storybook/addon-docs": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/addon-themes": "^8.5.0",
    "@storybook/react-vite": "^8.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^0.11.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "storybook": "^8.5.0",
    "style-dictionary": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
