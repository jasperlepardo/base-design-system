# Figma sync (scripts/sync-figma.mjs) — code → Figma variable push.
# Personal access token with "File content" + "Variables" write scopes.
FIGMA_TOKEN=
# The Figma file key to push variables into (from the file URL:
# figma.com/design/<FILE_KEY>/...). Created once, reused thereafter.
FIGMA_FILE_KEY=
# Optional separate file key for the components library. Defaults to
# FIGMA_FILE_KEY if unset.
FIGMA_COMPONENTS_FILE_KEY=
# Note: the REST variable push (npm run figma:push / jspr gen figma --push
# variables) requires a Figma Enterprise org. On non-Enterprise plans, use the
# MCP plugin push scripts in figma/push/ instead.
