# Figma sync (scripts/sync-figma.mjs) — code → Figma variable push.
# Personal access token with "File content" + "Variables" write scopes.
FIGMA_TOKEN=
# The Figma file key to push variables into (from the file URL:
# figma.com/design/<FILE_KEY>/...). Created once, reused thereafter.
FIGMA_FILE_KEY=
